{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StateModel",
  "type": "object",
  "properties": {
    "isConnected": {
      "type": "boolean",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxCheckBox",
          "editorOptions": {
            "type": "boolean",
            "readOnly": true
          },
          "label": {
            "location": "left",
            "showColon": true,
            "text": "На связи"
          }
        },
        "colorizer": {
          "styleProps": [
            {
              "fill": {
                "red": false,
                "white": true
              },
              "stroke": {
                "yellow": false,
                "black": true
              }
            }
          ]
        }
      }
    },
    "tempOutAir": {
      "type": "number",
      "unit": "°C",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Температура наружная"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "tempInNet": {
      "type": "number",
      "unit": "°C",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Температура на подаче контура ГВ"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "pressInNet": {
      "type": "number",
      "unit": "бар",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Давление на подаче горячей воды"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "tempOutHW": {
      "type": "number",
      "unit": "°C",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Температура обратки ГВ"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "tempOutNet": {
      "type": "number",
      "unit": "°C",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Температура обратки в сеть"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "pressOutNet": {
      "type": "number",
      "unit": "бар",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Давление на обратке горячей воды"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "pressOutAfterPump": {
      "type": "number",
      "unit": "бар",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Давление на обратке после насоса"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "pressInCW": {
      "type": "number",
      "unit": "бар",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxNumberBox",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Давление подводящей холодной воды"
          },
          "editorOptions": {
            "readOnly": true
          }
        },
        "chart": {}
      }
    },
    "timestamp": {
      "type": "integer",
      "ui": {
        "group": 1,
        "editor": {
          "editorType": "dxDateBox",
          "editorOptions": {
            "type": "datetime",
            "displayFormat": "dd.MM.yyyy HH:mm:ss",
            "readOnly": true
          },
          "cssClass": "form-input-box",
          "label": {
            "location": "top",
            "showColon": true,
            "text": "Время опроса"
          }
        }
      }
    }
  },
  "required": [
    "isConnected",
    "tempOutAir",
    "tempInNet",

    "pressInNet",
    "tempOutNet",
    "pressOutNet",
    "pressOutAfterPump",
    "pressInCW",
    "tempOutHW"
  ],
  "ui": {
    "useTabs": true,
    "groups": [
      {
        "id": 1,
        "name": "state",
        "caption": "Состояния",
        "order": 100
      }
    ]
  }
}