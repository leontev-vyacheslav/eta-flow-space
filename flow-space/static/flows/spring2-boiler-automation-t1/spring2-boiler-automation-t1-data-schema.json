  "$defs": {
    "SensorStatus": {
      "type": "integer",
      "enum": [
        1,
        2,
        4,
        8,
        16,
        32
      ],
      "enumDescriptions": {
        "1": "NORM - Норма",
        "2": "WARNING - Предупреждение (выход параметра за предупр. границы)",
        "4": "ALARM - Авария (выход параметра за аварийные границы)",
        "8": "SENSOR_FAULT - Неисправность датчика",
        "16": "WRONG_CALIBRATION - Неправильная калибровка",
        "32": "OVERLOAD - Перегрузка (выход сигнала датчика за установленные границы)"
      }
    },
    "SourcePumpStatus": {
      "type": "integer",
      "enum": [
        1,
        2,
        4,
        8,
        16,
        32,
        128,
        256,
        512,
        1024
      ],
      "enumDescriptions": {
        "1": "NO_POWER - Нет питания",
        "2": "STOPPED - Остановлен",
        "4": "OPERATING - В работе",
        "8": "ALARM - Авария",
        "16": "STARTUP_ACCELERATION - Запуск (разгон)",
        "32": "STOP - Останов",
        "128": "REGULATION_MIN_FREQUENCY - Регулирование (мин. частота)",
        "256": "REGULATION_MAX_FREQUENCY - Регулирование (макс. частота)",
        "512": "WAITING_FOR_START - Ожидание включения",
        "1024": "WAITING_FOR_READINESS - Ожидание готовности"
      }
    },
    "BoilerState": {
      "type": "integer",
      "enum": [
        1,
        2,
        4,
        8,
        16,
        32,
        64,
        128
      ],
      "enumDescriptions": {
        "1": "NOT_READY - Нет готовности",
        "2": "STOPPED - Отключен",
        "4": "STARTING - Включается",
        "8": "OPERATION_STAGE1 - Работа (на 1 ступени)",
        "16": "OPERATION_STAGE2 - Работа (на 2 ступени)",
        "32": "HOT_RESERVE - В горячем резерве",
        "64": "STOPPING - Останавливается",
        "128": "ALARM - Авария"
      }
    },
    "BoilerOutputValveState": {
      "type": "integer",
      "enum": [
        1,
        2
      ],
      "enumDescriptions": {
        "1": "OPEN - Открыта",
        "2": "CLOSED - Закрыта"
      }
